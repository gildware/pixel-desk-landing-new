# Login page path (same-origin on landing)
PUBLIC_LOGIN_URL=/login

# API used by /login OTP flow
PUBLIC_API_URL=http://localhost:3002

# Where to send users after successful OTP verify (pixel-dashboard-admin)
PUBLIC_DASHBOARD_URL=http://localhost:5173

# Support link on the login form
PUBLIC_SUPPORT_URL=/resources/knowledge-base

# Same-origin proxy via Vite /api/proxy (avoids cross-origin cookie issues)
# Set true for local/dev when using the Astro vite proxy, or behind a reverse proxy in prod.
PUBLIC_USE_API_PROXY=true
