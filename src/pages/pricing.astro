<script>
  const root = document.querySelector('[data-billing-toggle]');
  const switchBtn = root?.querySelector('[data-billing-switch]');
  const labels = root?.querySelectorAll('[data-billing-label]');
  const prices = document.querySelectorAll('[data-price]');
  const growthSub = document.querySelector('[data-price-sub="growth"]');

  const subCopy = {
    annual: 'Billed annually (₹7,188/user/year) · ₹749/user/mo billed monthly',
    monthly: 'Billed monthly · ₹599/user/mo with annual billing',
  };

  function setBilling(mode) {
    const annual = mode === 'annual';
    switchBtn?.setAttribute('aria-checked', String(annual));
    labels?.forEach((label) => {
      const key = label.getAttribute('data-billing-label');
      label.classList.toggle('is-active', key === mode);
    });
    prices.forEach((el) => {
      const value = annual ? el.getAttribute('data-annual') : el.getAttribute('data-monthly');
      const amount = el.querySelector('[data-amount]');
      if (amount && value) amount.textContent = value;
    });
    if (growthSub) growthSub.textContent = annual ? subCopy.annual : subCopy.monthly;
  }

  switchBtn?.addEventListener('click', () => {
    const annual = switchBtn.getAttribute('aria-checked') === 'true';
    setBilling(annual ? 'monthly' : 'annual');
  });
</script>
