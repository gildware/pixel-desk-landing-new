---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

type ResourceCard = {
  title: string;
  body: string;
  href: string;
  icon: string;
};

type ResourceSection = {
  heading: string;
  cards: ResourceCard[];
  cols: 1 | 2 | 3;
};

const sections: ResourceSection[] = [
  {
    heading: 'For Users',
    cols: 3,
    cards: [
      {
        title: 'Knowledge Base',
        body: 'Get knowledge of the features, their usage, and implementation.',
        href: '/resources/knowledge-base',
        icon: '/images/resources/icon-knowledge-base.svg',
      },
      {
        title: 'FAQs',
        body: 'Browse through our FAQs and find information that helps you to quickly resolve most common problems.',
        href: '/#faq',
        icon: '/images/resources/icon-faqs.svg',
      },
      {
        title: 'Community',
        body: 'Connect with community for your questions answered and share tips with other users',
        href: '#',
        icon: '/images/resources/icon-community.svg',
      },
    ],
  },
  {
    heading: 'For Developers',
    cols: 2,
    cards: [
      {
        title: 'API Guide',
        body: 'Understand and integrate PixelDesk service with third-party applications using API.',
        href: '#',
        icon: '/images/resources/icon-api.svg',
      },
      {
        title: 'Extension Guide',
        body: 'Browse through our FAQs and find information that helps you to quickly resolve most common problems.',
        href: '#',
        icon: '/images/resources/icon-extension.svg',
      },
    ],
  },
  {
    heading: 'Learning',
    cols: 1,
    cards: [
      {
        title: 'Video Tutorials',
        body: 'Watch our videos to get started with PixelDesk. Find the best tips and tricks for some of our most important features.',
        href: '#',
        icon: '/images/resources/icon-video.svg',
      },
    ],
  },
  {
    heading: 'Updates',
    cols: 2,
    cards: [
      {
        title: "What's New",
        body: 'Get the latest news on product updates and enhancements from the PixelDesk.',
        href: '#',
        icon: '/images/resources/icon-whats-new.svg',
      },
      {
        title: 'Blogs',
        body: 'Read insightful articles by the PixelDesk team as they discuss a wide range of topics, from product news to project management.',
        href: '#',
        icon: '/images/resources/icon-blogs.svg',
      },
    ],
  },
];
---

<BaseLayout
  title="Resources"
  description="Videos, docs, FAQs, API references, and more to help you get the most out of Pixeldesk."
>
  <Header current="resources" />
  <main class="resources-page">
    <section class="resources-hero relative overflow-hidden pt-[140px] pb-10 sm:pt-[160px] sm:pb-12">
      <div class="resources-hero__glow" aria-hidden="true"></div>
      <div class="pd-rail relative z-[1] text-center">
        <h1 class="text-[40px] font-medium leading-[48px] tracking-tight text-navy sm:text-[50px] sm:leading-[52px]">
          Resources
        </h1>
        <p class="mx-auto mt-4 max-w-[714px] text-[15px] font-light leading-[24px] text-navy sm:mt-5 sm:text-[16px]">
          Built for three audiences at once — the Project Manager who needs control, the team that needs clarity, and the
          client who needs confidence in what’s being delivered.
        </p>

        <form class="resources-search mx-auto mt-8 w-full max-w-[562px]" role="search" action="/resources" method="get">
          <label class="sr-only" for="resource-search">Search resources</label>
          <div class="resources-search__field">
            <input
              id="resource-search"
              name="q"
              type="search"
              placeholder=""
              class="h-[42px] w-full rounded-full border-0 bg-white px-5 pr-12 text-[14px] font-light text-navy outline-none placeholder:text-label"
            />
            <span class="resources-search__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="8" cy="8" r="5.5" stroke="#000945" stroke-width="1.2"></circle>
                <path d="M12.5 12.5 16 16" stroke="#000945" stroke-width="1.2" stroke-linecap="round"></path>
              </svg>
            </span>
          </div>
        </form>
      </div>
    </section>

    <section class="pb-20 sm:pb-24">
      <div class="pd-rail space-y-12 sm:space-y-[50px]">
        {
          sections.map((section) => (
            <div>
              <h2 class="text-[20px] font-medium leading-[24px] text-navy">{section.heading}</h2>
              <div
                class:list={[
                  'mt-4 grid gap-5 sm:gap-7',
                  section.cols === 3 && 'sm:grid-cols-2 lg:grid-cols-3',
                  section.cols === 2 && 'sm:grid-cols-2 lg:grid-cols-3',
                  section.cols === 1 && 'sm:grid-cols-2 lg:grid-cols-3',
                ]}
              >
                {section.cards.map((card) => (
                  <a
                    href={card.href}
                    class="resources-card group flex min-h-[222px] flex-col gap-[15px] rounded-[15px] border border-line bg-white p-5 transition hover:-translate-y-0.5"
                  >
                    <span class="relative size-[41px] shrink-0">
                      <img
                        src={card.icon}
                        alt=""
                        width="69"
                        height="69"
                        class="absolute inset-[-14px] size-[69px] max-w-none"
                      />
                    </span>
                    <h3 class="text-[20px] font-medium leading-[24px] text-navy">{card.title}</h3>
                    <p class="flex-1 text-[12px] font-light leading-[18px] text-navy">{card.body}</p>
                    <span class="pd-chip w-fit">Learn More</span>
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .resources-hero__glow {
    pointer-events: none;
    position: absolute;
    inset: 0;
    height: min(1006px, 100%);
    background-image: url("data:image/svg+xml;utf8,<svg viewBox='0 0 1512 1006' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='none'><rect width='100%' height='100%' fill='url(%23g)' opacity='0.96'/><defs><radialGradient id='g' gradientUnits='userSpaceOnUse' cx='0' cy='0' r='10' gradientTransform='matrix(2.8831e-14 -230.33 346.19 1.6766e-13 756 932.01)'><stop stop-color='rgba(255,255,255,1)' offset='0.30769'/><stop stop-color='rgba(218,208,255,0.75)' offset='0.48077'/><stop stop-color='rgba(182,160,255,0.5)' offset='0.65385'/><stop stop-color='rgba(108,65,255,0)' offset='1'/></radialGradient></defs></svg>");
    background-size: 100% 100%;
    background-repeat: no-repeat;
  }

  .resources-search__field {
    position: relative;
    border-radius: 21px;
    background: #fff;
    box-shadow: 6px 6px 33px rgba(108, 65, 255, 0.21);
  }

  .resources-search__icon {
    position: absolute;
    top: 50%;
    right: 18px;
    display: flex;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .resources-card {
    box-shadow: none;
  }

  .resources-card:hover {
    box-shadow: 5px 5px 16px rgba(0, 0, 0, 0.06);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
