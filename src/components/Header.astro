---
interface Props {
  current?: 'home' | 'features' | 'pricing' | 'resources';
}

const { current = 'home' } = Astro.props;

const loginUrl = import.meta.env.PUBLIC_LOGIN_URL || '/login';

const links = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/features', label: 'Features', key: 'features' },
  { href: '/pricing', label: 'Pricing', key: 'pricing' },
  { href: '/resources', label: 'Resources', key: 'resources' },
] as const;
---

<header class="pointer-events-none absolute inset-x-0 top-0 z-50">
  <div class="pd-frame pointer-events-auto px-5 pt-[58px] sm:px-8 lg:px-[251px] lg:pt-[58px]">
    <nav class="pd-nav-shell flex items-center justify-between gap-4 px-5" aria-label="Primary">
      <a href="/" class="shrink-0" aria-label="Pixeldesk home">
        <img src="/images/logo.svg" alt="Pixeldesk" width="155" height="30" class="h-[30px] w-[155px]" />
      </a>

      <ul class="hidden items-center gap-[47px] text-[12px] font-light leading-[14px] text-navy md:flex">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[current === link.key && 'font-medium text-purple']}
                aria-current={current === link.key ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-2">
        <a href={loginUrl} class="pd-btn-login hidden sm:inline-flex">Log in</a>
        <button
          type="button"
          class="inline-flex size-9 items-center justify-center rounded-full border border-line text-navy md:hidden"
          data-menu-toggle
          aria-expanded="false"
          aria-controls="mobile-nav"
          aria-label="Open menu"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
          </svg>
        </button>
      </div>
    </nav>

    <div id="mobile-nav" class="mt-2 hidden rounded-2xl border border-line bg-white p-4 shadow-lg md:hidden" hidden>
      <ul class="flex flex-col gap-3 text-sm text-navy">
        {
          links.map((link) => (
            <li>
              <a href={link.href} class="block py-1" aria-current={current === link.key ? 'page' : undefined}>
                {link.label}
              </a>
            </li>
          ))
        }
        <li><a href={loginUrl} class="pd-btn-login mt-1 w-full">Log in</a></li>
      </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const panel = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    if (!panel || !toggle) return;
    const open = !panel.hasAttribute('hidden');
    if (open) {
      panel.setAttribute('hidden', '');
      panel.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      panel.removeAttribute('hidden');
      panel.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });
</script>
