---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Your next project deserves a better home.',
  subtitle = "Join thousands of teams who've replaced disconnected tools with one workspace that actually works.",
} = Astro.props;
---

<section class="pb-16 sm:pb-24">
  <div class="pd-rail">
    <div class="rounded-[14px] bg-purple px-6 py-12 text-center text-white sm:px-10 sm:py-14">
      <h2 class="mx-auto max-w-[416px] text-[32px] font-medium leading-[35px] sm:text-[36px] sm:leading-[35px]">
        {title}
      </h2>
      <p class="mx-auto mt-4 max-w-[455px] text-[14px] font-light leading-[17px] text-white/90">
        {subtitle}
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-[23px]">
        <a
          href="/pricing"
          class="inline-flex h-[34px] min-w-[147px] items-center justify-center rounded-[25px] bg-white px-5 text-[14px] font-normal text-purple"
        >
          Start free today
        </a>
        <a
          href="#"
          class="inline-flex h-[34px] min-w-[147px] items-center justify-center rounded-[25px] border border-white/50 bg-transparent px-5 text-[14px] font-normal text-white"
        >
          Book a live demo
        </a>
      </div>
    </div>
  </div>
</section>
